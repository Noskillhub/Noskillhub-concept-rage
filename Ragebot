-- Teleport (closer, above bias ~15 studs random)
local function doTeleport()
    local targets = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local h = p.Character:FindFirstChildOfClass("Humanoid")
            if h and h.Health > 0 then table.insert(targets, p) end
        end
    end
    
    local myChar = lp.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end
    local myRoot = myChar.HumanoidRootPart
    
    if #targets > 0 then
        local tgt = targets[math.random(#targets)]
        local tRoot = tgt.Character.HumanoidRootPart
        local off = Vector3.new(math.random(-180,180), math.random(140,280), math.random(-180,180))
        myRoot.CFrame = tRoot.CFrame * CFrame.new(off)
    else
        myRoot.CFrame = CFrame.new(math.random(-1400,1400), skyHeight + 250, math.random(-1400,1400))
    end
end

-- Sky camp
local function skyLoop()
    if skyConn then return end
    skyConn = RunService.Heartbeat:Connect(function()
        if not _G.SkyCampEnabled or touchDown then return end
        local char = lp.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            local r = char.HumanoidRootPart
            r.AssemblyLinearVelocity = Vector3.zero
            r.CFrame = CFrame.new(r.Position.X, skyHeight, r.Position.Z)
        end
    end)
end

local function onPress(input, gp)
    if gp then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        touchDown = true
        _G.SkyCampEnabled = false
        doTeleport()
        if _G.StickyKillEnabled then
            currentTarget = getClosest()
            if currentTarget then
                attacking = true
                startStick()
            end
        end
    end
end

local function onRelease(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        touchDown = false
        stopStick()
        _G.SkyCampEnabled = true
    end
end

