function getClosest()
    local best, bestDist = nil, 9999
    local m = lp:GetMouse()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 and (not p.Team or p.Team ~= lp.Team) then
                local pos, vis = cam:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
                if vis then
                    local d = (Vector2.new(pos.X, pos.Y) - Vector2.new(m.X, m.Y)).Magnitude
                    if d < bestDist and d < 280 then
                        best, bestDist = p, d
                    end
                end
            end
        end
    end
    return best
end

